# Amnos Browser Security Configuration
# ====================================
# BALANCED CONFIGURATION: Strong privacy + working search/browsing

# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 DEBUG & DEVELOPMENT MODES (Top Priority - Check These First)
# ═══════════════════════════════════════════════════════════════════════════════

# MASTER DEBUG MODE
# Relaxes several security checks to fix blank screens/rendering issues.
# Use: Debugging only — disables strict policies that may break page rendering in dev builds.
# ⚠️ Keep FALSE for production use
SECURITY_RELAX_FOR_DEBUG=false

# UI SCREENSHOT PROTECTION
# Prevents screenshots and screen recordings of the app (FLAG_SECURE).
# Use: Stops sensitive browsing sessions from being captured by other apps or the system.
# ⚠️ Set to FALSE for normal use (screenshots allowed), TRUE for maximum privacy
SECURITY_BLOCK_SCREENSHOTS=false

# ═══════════════════════════════════════════════════════════════════════════════
# ✅ SAFE FEATURES (Enable these - won't break normal browsing)
# ═══════════════════════════════════════════════════════════════════════════════

# Blocks known tracker domains using a built-in blocklist.
# Use: Prevents ad networks and analytics services from profiling your browsing activity.
# ✅ SAFE - Blocks only known trackers, sites work normally
# Note: Uses 200+ domain blocklist + pattern matching + keyword detection
SECURITY_BLOCK_TRACKERS=false

# Aggressive ad/tracker blocking using URL pattern matching
# Use: Blocks ads/trackers by detecting common patterns in URLs (e.g., /ads/, /tracking/, etc.)
# ✅ SAFE - Catches trackers not in blocklist, may rarely block legitimate resources
SECURITY_AGGRESSIVE_AD_BLOCKING=false

# Denies all cleartext (HTTP) requests; forces HTTPS for every connection.
# Use: Ensures all traffic is encrypted in transit, preventing MITM attacks on plain HTTP.
# ✅ SAFE - Modern sites use HTTPS, old HTTP sites will be blocked (expected behavior)
SECURITY_HTTPS_ONLY=false

# Removes known tracking query parameters (e.g. utm_source, fbclid) from URLs.
# Use: Cleans URLs before navigation so analytics platforms cannot correlate sessions via URL params.
# ✅ SAFE - Only removes tracking params, doesn't affect site functionality
SECURITY_REMOVE_TRACKING_PARAMS=false

# Shuts down WebRTC APIs and replaces them with fake peer connection objects at document-start.
# Use: Prevents WebRTC IP leaks that can expose your real local and public IP addresses.
# ✅ SAFE - Only video chat sites need WebRTC, search/browsing works fine
SECURITY_BLOCK_WEBRTC=false

# Blocks DNS prefetch hints (<link rel="dns-prefetch">).
# Use: Stops the browser from pre-resolving domains in the background, which leaks visited-site intent.
# ✅ SAFE - Only affects performance optimization, not functionality
SECURITY_BLOCK_DNS_PREFETCH=false

# Blocks preconnect hints (<link rel="preconnect">).
# Use: Prevents early TCP/TLS handshakes to third-party servers before the user actually navigates there.
# ✅ SAFE - Only affects performance optimization, not functionality
SECURITY_BLOCK_PRECONNECT=false

# Disables Service Worker registration and caching.
# Use: Eliminates a persistent storage vector that survives normal cache clears and can track users across sessions.
# ✅ SAFE - Most sites work without service workers (only PWAs and offline features affected)
SECURITY_BLOCK_SERVICE_WORKERS=false

# Blocks IPv6 address resolution and connections.
# Use: Prevents IPv6-based IP leak vectors that can bypass IPv4-only proxy or VPN configurations.
# ✅ SAFE - Most sites work fine with IPv4 only
SECURITY_BLOCK_IPV6=false

# Fingerprint protection level: BALANCED, STRICT, or FALSE
# BALANCED: Session-consistent fake identity, realistic device profiles, blends into crowd
# STRICT: Tab-specific identity, UTC timezone only, maximum randomization
# FALSE: (Recommended for debugging ONLY) Disables fingerprint spoofing entirely
# Use: Prevents browser fingerprinting by faking User-Agent, screen, GPU, canvas, audio, fonts, timezone
# ✅ SAFE - Use BALANCED/STRICT to stay anonymous. Set to FALSE only if features break.
SECURITY_FINGERPRINT_LEVEL=false

# Blocks WebSocket connections (ws:// and wss://).
# Use: Prevents persistent bidirectional channels that can be used for covert data exfiltration or fingerprinting.
# ✅ MOSTLY SAFE - Some chat apps and real-time features may break, but search/browsing works fine
SECURITY_BLOCK_WEBSOCKETS=false

# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ RISKY & EXPERIMENTAL FEATURES (These WILL break sites - use with caution)
# ═══════════════════════════════════════════════════════════════════════════════

# Blocks all network requests to domains different from the current top-level site.
# Use: Stops cross-site resource loading that can be used for tracking or data exfiltration.
# ⚠️ BREAKS SITES - Search engines load CSS/JS/images from CDNs (gstatic.com, etc.)
# Keep FALSE for normal browsing
SECURITY_BLOCK_THIRD_PARTY_REQUESTS=false

# Blocks JavaScript files loaded from third-party origins.
# Use: Prevents third-party scripts (e.g. tag managers, analytics) from executing in the page.
# ⚠️ BREAKS SITES - Many sites load core JS from CDNs (jQuery, React, etc.)
# Keep FALSE for normal browsing
SECURITY_BLOCK_THIRD_PARTY_SCRIPTS=false

# Blocks inline <script> tags inside page HTML.
# Use: Mitigates XSS attacks that inject malicious scripts directly into page markup.
# ⚠️ BREAKS SITES - Most sites use inline scripts for initialization
# Keep FALSE for normal browsing
SECURITY_BLOCK_INLINE_SCRIPTS=false

# Strips the Referer header from outgoing requests.
# Use: Hides which page you came from, preventing sites from tracking your navigation path.
# ⚠️ MAY BREAK SITES - Some sites check referer for security (payment gateways, etc.)
# Keep FALSE for normal browsing
SECURITY_STRIP_REFERRERS=false

# Blocks eval() and Function() constructor calls in JavaScript.
# Use: Reduces the attack surface for XSS and code-injection exploits that rely on dynamic code execution.
# ⚠️ MAY BREAK SITES - Some sites use eval() for templating or dynamic features
# Keep FALSE for normal browsing
SECURITY_BLOCK_EVAL=false

# Routes all DNS resolution through the local loopback proxy backed by DNS-over-HTTPS (DoH).
# Use: Encrypts DNS queries so your ISP or network observer cannot see which domains you resolve.
# ⚠️ EXPERIMENTAL - May cause connection issues on some networks
# Keep FALSE unless you specifically need DoH
SECURITY_ENFORCE_LOOPBACK_PROXY=false

# Rebuilds the tab's WebView silo when the top-level site identity changes.
# Use: Enforces hard first-party isolation so cookies, storage, and cache cannot leak across sites.
# ⚠️ BREAKS NAVIGATION - Reloads page on every cross-site link click
# Keep FALSE for normal browsing
SECURITY_STRICT_FIRST_PARTY_ISOLATION=false

# ═══════════════════════════════════════════════════════════════════════════════
# 📋 QUICK REFERENCE GUIDE
# ═══════════════════════════════════════════════════════════════════════════════
#
# 🟢 NORMAL BROWSING (Current Config - Recommended):
#    ✅ All SAFE features enabled
#    ❌ All RISKY features disabled
#    Result: Search engines work, trackers blocked, strong privacy
#
# 🟡 MAXIMUM PRIVACY (Some sites may break):
#    Enable from RISKY section: BLOCK_THIRD_PARTY_SCRIPTS, STRIP_REFERRERS, BLOCK_EVAL
#    Keep disabled: BLOCK_THIRD_PARTY_REQUESTS, BLOCK_INLINE_SCRIPTS
#    Result: Stronger privacy, some sites may have broken features
#
# 🔴 PARANOID MODE (Many sites will break):
#    Enable: ALL RISKY features
#    Result: Maximum privacy, expect blank pages and broken layouts
#
# 🔧 TROUBLESHOOTING (If you see blank pages):
#    1. Set SECURITY_RELAX_FOR_DEBUG=true
#    2. Test if site loads
#    3. If it works, the issue is one of the security features
#    4. Disable RISKY features one by one to find the culprit
#    5. Set SECURITY_RELAX_FOR_DEBUG=false when done
#
# ═══════════════════════════════════════════════════════════════════════════════
