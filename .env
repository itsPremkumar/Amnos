# Amnos Browser Security Configuration
# ====================================
# Default: All security features are ENABLED.
# Set to 'false' only for debugging or specific site compatibility.

# UI PROTECTION
# If true, prevents screenshots and screen recordings of the app.
SECURITY_BLOCK_SCREENSHOTS=true

# MASTER DEBUG MODE
# If true, relaxes several security checks to fix blank screens/rendering issues.
SECURITY_RELAX_FOR_DEBUG=true

# NETWORK SECURITY
SECURITY_BLOCK_TRACKERS=false
SECURITY_HTTPS_ONLY=false
SECURITY_BLOCK_THIRD_PARTY_REQUESTS=false
SECURITY_BLOCK_THIRD_PARTY_SCRIPTS=false
SECURITY_BLOCK_INLINE_SCRIPTS=false
SECURITY_STRIP_REFERRERS=false
SECURITY_REMOVE_TRACKING_PARAMS=false
SECURITY_BLOCK_WEBSOCKETS=false
SECURITY_BLOCK_WEBRTC=false
SECURITY_BLOCK_DNS_PREFETCH=false
SECURITY_BLOCK_PRECONNECT=false

# ENGINE SECURITY
SECURITY_BLOCK_SERVICE_WORKERS=false
SECURITY_BLOCK_EVAL=false
SECURITY_BLOCK_IPV6=false
SECURITY_ENFORCE_LOOPBACK_PROXY=false
SECURITY_STRICT_FIRST_PARTY_ISOLATION=false
