# Amnos Browser Security Configuration
# Production release profile: strong privacy without enabling the most site-breaking experiments.

# Core hardening
SECURITY_ENFORCE_STRICT_POLICIES=true
SECURITY_BLOCK_FORENSIC_LOGGING=true
SECURITY_BLOCK_SCREENSHOTS=true

# Safe-by-default protections
SECURITY_BLOCK_TRACKERS=true
SECURITY_AGGRESSIVE_AD_BLOCKING=true
SECURITY_HTTPS_ONLY=true
SECURITY_REMOVE_TRACKING_PARAMS=true
SECURITY_BLOCK_WEBRTC=true
SECURITY_BLOCK_DNS_PREFETCH=true
SECURITY_BLOCK_PRECONNECT=true
SECURITY_BLOCK_SERVICE_WORKERS=true
SECURITY_BLOCK_IPV6=true
SECURITY_FINGERPRINT_LEVEL=STRICT
SECURITY_BLOCK_WEBSOCKETS=true

# Experimental / breakage-prone protections
SECURITY_BLOCK_THIRD_PARTY_REQUESTS=false
SECURITY_BLOCK_THIRD_PARTY_SCRIPTS=false
SECURITY_BLOCK_INLINE_SCRIPTS=false
SECURITY_STRIP_REFERRERS=false
SECURITY_BLOCK_EVAL=false
SECURITY_ENFORCE_LOOPBACK_PROXY=false
SECURITY_STRICT_FIRST_PARTY_ISOLATION=false
