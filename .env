# Amnos Browser Security Configuration
# ====================================
# Default: All security features are ENABLED.
# Set to 'false' only for debugging or specific site compatibility.

# UI PROTECTION
# Prevents screenshots and screen recordings of the app (FLAG_SECURE).
# Use: Stops sensitive browsing sessions from being captured by other apps or the system.
SECURITY_BLOCK_SCREENSHOTS=false

# MASTER DEBUG MODE
# Relaxes several security checks to fix blank screens/rendering issues.
# Use: Debugging only — disables strict policies that may break page rendering in dev builds.
SECURITY_RELAX_FOR_DEBUG=false

# NETWORK SECURITY

# Blocks known tracker domains using a built-in blocklist.
# Use: Prevents ad networks and analytics services from profiling your browsing activity.
SECURITY_BLOCK_TRACKERS=true

# Denies all cleartext (HTTP) requests; forces HTTPS for every connection.
# Use: Ensures all traffic is encrypted in transit, preventing MITM attacks on plain HTTP.
SECURITY_HTTPS_ONLY=true

# Blocks all network requests to domains different from the current top-level site.
# Use: Stops cross-site resource loading that can be used for tracking or data exfiltration.
SECURITY_BLOCK_THIRD_PARTY_REQUESTS=false

# Blocks JavaScript files loaded from third-party origins.
# Use: Prevents third-party scripts (e.g. tag managers, analytics) from executing in the page.
SECURITY_BLOCK_THIRD_PARTY_SCRIPTS=false

# Blocks inline <script> tags inside page HTML.
# Use: Mitigates XSS attacks that inject malicious scripts directly into page markup.
SECURITY_BLOCK_INLINE_SCRIPTS=false

# Strips the Referer header from outgoing requests.
# Use: Hides which page you came from, preventing sites from tracking your navigation path.
SECURITY_STRIP_REFERRERS=false

# Removes known tracking query parameters (e.g. utm_source, fbclid) from URLs.
# Use: Cleans URLs before navigation so analytics platforms cannot correlate sessions via URL params.
SECURITY_REMOVE_TRACKING_PARAMS=true

# Blocks WebSocket connections (ws:// and wss://).
# Use: Prevents persistent bidirectional channels that can be used for covert data exfiltration or fingerprinting.
SECURITY_BLOCK_WEBSOCKETS=true

# Shuts down WebRTC APIs and replaces them with fake peer connection objects at document-start.
# Use: Prevents WebRTC IP leaks that can expose your real local and public IP addresses.
SECURITY_BLOCK_WEBRTC=true

# Blocks DNS prefetch hints (<link rel="dns-prefetch">).
# Use: Stops the browser from pre-resolving domains in the background, which leaks visited-site intent.
SECURITY_BLOCK_DNS_PREFETCH=true

# Blocks preconnect hints (<link rel="preconnect">).
# Use: Prevents early TCP/TLS handshakes to third-party servers before the user actually navigates there.
SECURITY_BLOCK_PRECONNECT=true

# ENGINE SECURITY

# Disables Service Worker registration and caching.
# Use: Eliminates a persistent storage vector that survives normal cache clears and can track users across sessions.
SECURITY_BLOCK_SERVICE_WORKERS=true

# Blocks eval() and Function() constructor calls in JavaScript.
# Use: Reduces the attack surface for XSS and code-injection exploits that rely on dynamic code execution.
SECURITY_BLOCK_EVAL=false

# Blocks IPv6 address resolution and connections.
# Use: Prevents IPv6-based IP leak vectors that can bypass IPv4-only proxy or VPN configurations.
SECURITY_BLOCK_IPV6=true

# Routes all DNS resolution through the local loopback proxy backed by DNS-over-HTTPS (DoH).
# Use: Encrypts DNS queries so your ISP or network observer cannot see which domains you resolve.
SECURITY_ENFORCE_LOOPBACK_PROXY=false

# Rebuilds the tab's WebView silo when the top-level site identity changes.
# Use: Enforces hard first-party isolation so cookies, storage, and cache cannot leak across sites.
SECURITY_STRICT_FIRST_PARTY_ISOLATION=false
