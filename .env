###############################################################################
# AMNOS V3.1 - ADVANCED STEALTH & ANTI-FORENSIC CONFIGURATION (.env)
###############################################################################
# POLICY CONVENTION: 
# [true]  = SECURED / ENABLED (Production Hardening)
# [false] = RELAXED / DISABLED (Development/Debugging)
###############################################################################

# =============================================================================
# --- 🛠️ SECTION 0: DEVELOPER COCKPIT (DEBUG & LOGGING) ---
# =============================================================================
# Use these two switches to control the application's developer posture.

# 1. MASTER DEBUGGER SWITCH
# -------------------------
# [true]  = SECURED: Anti-Debugger is ACTIVE. Chrome DevTools is BLOCKED. 
#           The app will self-destruct if a debugger is connected.
# [false] = DEBUG MODE: Anti-Debugger is DISABLED. Chrome DevTools is ENABLED.
#           Use this if you need to use Android Studio or inspect WebViews.
SECURITY_LOCKDOWN_MODE=true

# 2. MASTER LOGCAT / FORENSIC LOGGING TOGGLE
# ------------------------------------------
# [true]  = SECURED: App logs are strictly internal. System Logcat is SILENT.
#           This prevents sensitive URLs or state from leaking to Android logs.
# [false] = LOGCAT ON: Enables full forensic logging to the system console.
#           Use this to diagnose network issues or see full application traces.
SECURITY_BLOCK_FORENSIC_LOGGING=false

# =============================================================================


# --- CATEGORY 1: INTEGRITY & SANDBOX ---
# Controls the runtime environment and prevents external inspection.

# If [true], the app will trigger an immediate memory wipe and self-destruct 
# if a debugger (like Android Studio or ADB) is attached to the process.
SECURITY_ANTI_DEBUGGER=true

# Master toggle for overall strict policy enforcement. 
# Affects how aggressively the system handles minor policy violations.
SECURITY_ENFORCE_STRICT_POLICIES=true

# Security Pre-set: [PARANOID] (Maximum isolation), [BALANCED], or [OPEN].
# Affects default handling of navigation safety and permission gates.
SECURITY_SANDBOX_MODE=BALANCED

# Automatic Session Time-to-Live (TTL). The session is wiped after this duration.
SECURITY_SESSION_TIMEOUT_MS=120000


# --- CATEGORY 2: NETWORK ISOLATION ---
# Controls how data enters and leaves the device.

# If [true], all network traffic is forced through the internal secure loopback proxy (127.0.0.1).
# Any attempt to bypass this proxy will result in a connection failure.
SECURITY_ENFORCE_LOOPBACK_PROXY=true

# Forces every connection to use TLS (HTTPS). Insecure HTTP requests are blocked.
SECURITY_HTTPS_ONLY=true

# Blocks WebRTC to prevent local IP leaks (Peer-to-Peer leaks).
SECURITY_BLOCK_WEBRTC=true

# Disables IPv6 to prevent leakage via modern network interfaces if the proxy is IPv4 only.
SECURITY_BLOCK_IPV6=true

# Disables DNS Prefetching to prevent the browser from leaking hostnames via DNS lookups.
SECURITY_BLOCK_DNS_PREFETCH=true

# Prevents the browser from establishing speculative connections to minimize network noise.
SECURITY_BLOCK_PRECONNECT=true

# Blocks WebSockets to prevent persistent, stateful socket connections.
SECURITY_BLOCK_WEBSOCKETS=true


# --- CATEGORY 3: PRIVACY & ANTI-FINGERPRINTING ---
# Prevents websites from identifying your device or tracking your movement.

# Spoofing Level: [STRICT] (High entropy noise), [BALANCED], or [DISABLED].
# Prevents Canvas, WebGL, and Audio hardware fingerprinting.
SECURITY_FINGERPRINT_LEVEL=STRICT

# Blocks common tracking scripts and telemetric endpoints globally.
SECURITY_BLOCK_TRACKERS=true

# Aggressive removal of advertisement DOM elements and network requests.
SECURITY_AGGRESSIVE_AD_BLOCKING=true

# Strips tracking suffixes (like ?utm_source=...) from URLs before navigation.
SECURITY_REMOVE_TRACKING_PARAMS=true

# Prevents the browser from sending the 'Referer' header to minimize cross-site tracking.
SECURITY_STRIP_REFERRERS=true

# Enforces strict isolation per First-Party domain (Prevents Cross-Site Tracking).
SECURITY_STRICT_FIRST_PARTY_ISOLATION=true


# --- CATEGORY 4: WEB ENGINE HARDENING ---
# Locks down the internal browser logic to prevent script exploits.

# If [true], modern Chrome DevTools / Remote Inspection is physically BLOCKED inside the WebView.
SECURITY_BLOCK_REMOTE_DEBUGGING=true

# Blocks Service Workers to prevent background persistence and notification leaks.
SECURITY_BLOCK_SERVICE_WORKERS=true

# Blocks any network request that doesn't originate from the top-level main page.
SECURITY_BLOCK_THIRD_PARTY_REQUESTS=true

# Blocks scripts loaded from different domains (Prevents 99% of web tracking).
SECURITY_BLOCK_THIRD_PARTY_SCRIPTS=true

# Blocks inline scripts (scripts written directly in HTML). [Warning: May break some sites].
SECURITY_BLOCK_INLINE_SCRIPTS=false

# Prevents the use of eval() and similar JavaScript execution traps.
SECURITY_BLOCK_EVAL=true


# --- CATEGORY 5: OS & FORENSIC PROTECTION ---
# Prevents local data leakage to the physical device or the Android OS.

# If [true], the app's presence is hidden from the Android Dashboard and wiped from "Recents".
SECURITY_ABSOLUTE_CLOAKING=true

# If [true], sensitive RAM buffers are saturated with random noise before being cleared.
SECURITY_FORENSIC_RAM_SCRAMBLE=true

# If [true], Android blocks screenshots and screen recordings of the app.
SECURITY_BLOCK_SCREENSHOTS=true


# --- CATEGORY 6: STEALTH & CAMOUFLAGE ---
# Obfuscates the application's identity to prevent casual detection.

# Camouflage Profile: [CALCULATOR], [WEATHER], or [DISABLED].
# Swaps the App Icon and Label when the application goes to background.
SECURITY_CAMOUFLAGE_PROFILE=DISABLED

# The secret mathematical PIN used to unlock the real Amnos browser from the Decoy UI.
SECURITY_DECOY_UNLOCK_PIN=1111


# --- CATEGORY 7: HARDWARE & LIFECYCLE PURGE ---
# Automated triggers for irreversible data destruction.

# If [true], double-pressing the VOLUME DOWN hardware button triggers a total wipe.
SECURITY_PANIC_GESTURE_ENABLED=true

# If [true], the session is wiped immediately when the screen is turned off.
SECURITY_WIPE_ON_SCREEN_OFF=true

# If [true], the session is wiped when the app stays in background (Ghost Wipe).
SECURITY_WIPE_ON_BACKGROUND=true

# Delay in milliseconds before a backgrounded app is wiped (Grace Period).
SECURITY_BACKGROUND_WIPE_DELAY_MS=5000
