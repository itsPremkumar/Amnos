# Amnos Browser Security Configuration
# ====================================
# Default: All security features are ENABLED.
# Set to 'false' only for debugging or specific site compatibility.

# UI PROTECTION
# If true, prevents screenshots and screen recordings of the app.
SECURITY_BLOCK_SCREENSHOTS=true

# MASTER DEBUG MODE
# If true, relaxes several security checks to fix blank screens/rendering issues.
SECURITY_RELAX_FOR_DEBUG=false

# NETWORK SECURITY
SECURITY_BLOCK_TRACKERS=true
SECURITY_HTTPS_ONLY=true
SECURITY_BLOCK_THIRD_PARTY_REQUESTS=true
SECURITY_BLOCK_THIRD_PARTY_SCRIPTS=true
SECURITY_BLOCK_INLINE_SCRIPTS=true
SECURITY_STRIP_REFERRERS=true
SECURITY_REMOVE_TRACKING_PARAMS=true
SECURITY_BLOCK_WEBSOCKETS=true
SECURITY_BLOCK_WEBRTC=true
SECURITY_BLOCK_DNS_PREFETCH=true
SECURITY_BLOCK_PRECONNECT=true

# ENGINE SECURITY
SECURITY_BLOCK_SERVICE_WORKERS=true
SECURITY_BLOCK_EVAL=true
SECURITY_BLOCK_IPV6=true
SECURITY_ENFORCE_LOOPBACK_PROXY=true
SECURITY_STRICT_FIRST_PARTY_ISOLATION=true
