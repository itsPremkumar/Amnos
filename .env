###############################################################################
# AMNOS V3.2 - ULTIMATE STEALTH & ANTI-FORENSIC MASTER CONFIGURATION
###############################################################################
# This file controls the core security posture of the Amnos Browser.
# POLICY CONVENTION: 
# [true]  = SECURED / ENABLED (Hardened Privacy)
# [false] = RELAXED / DISABLED (Maximum Compatibility)
###############################################################################

# =============================================================================
# --- 🛡️ SECTION 1: CORE INTEGRITY & SANDBOX ---
# =============================================================================
# Controls the runtime environment and prevents external inspection.

# 1.1 Master Sandbox Preset
# Options: [PARANOID] (Maximum isolation), [BALANCED] (Normal Use), [OPEN] (Debug)
# BALANCED: Recommended for daily use. Blocks trackers but allows normal sites.
SECURITY_SANDBOX_MODE=PARANOID

# 1.2 Strict Policy Enforcement
# If true, the app will crash or block requests on minor security violations.
# Helps prevent "policy drift" where security weakens over time.
SECURITY_ENFORCE_STRICT_POLICIES=true


# =============================================================================
# --- 🔧 SECTION 2: DEVELOPER COCKPIT (DEBUG & LOGGING) ---
# =============================================================================
# Critical switches for development and technical debugging.

# 2.1 Master Lockdown Mode (Anti-Debugger)
# [true]  = SECURED: Anti-Debugger is ACTIVE. Chrome DevTools is BLOCKED. 
#           The app will self-destruct if a debugger is connected.
# [false] = DEBUG MODE: DevTools and Remote Inspection are ENABLED.
SECURITY_LOCKDOWN_MODE=true

# 2.2 Forensic Logging Control (Logcat)
# [true]  = SECURED: App logs are strictly internal. System Logcat is SILENT.
# [false] = LOGCAT ON: Enables full technical traces and the Internal Console.
# Recommendation: Set FALSE to use the new Internal System Console.
SECURITY_BLOCK_FORENSIC_LOGGING=true

# 2.3 UI Screenshot Protection (FLAG_SECURE)
# [true]  = SECURED: Android blocks all screenshots and screen recordings.
# [false] = RELAXED: Allows capturing your screen.
SECURITY_BLOCK_SCREENSHOTS=true


# =============================================================================
# --- 🌐 SECTION 3: NETWORK ISOLATION (SAFE FEATURES) ---
# =============================================================================
# Protections that enhance privacy without breaking normal website behavior.

# 3.1 HTTPS-Only Enforcement
# Forces every connection to use TLS (HTTPS). Insecure HTTP is physically blocked.
# ✅ SAFE: 99% of the modern web uses HTTPS.
SECURITY_HTTPS_ONLY=true

# 3.2 WebRTC Leak Protection
# Disables WebRTC APIs to prevent local/public IP leaks via STUN/TURN servers.
# ✅ SAFE: Only affects video chat sites (Meet, Zoom). Search/Browsing works fine.
SECURITY_BLOCK_WEBRTC=true

# 3.3 IPv6 Leak Protection
# Prevents IP leaks by disabling IPv6 resolution if the proxy is IPv4 only.
# ✅ SAFE: Websites load perfectly over IPv4.
SECURITY_BLOCK_IPV6=true

# 3.4 DNS Noise Reduction
# Blocks DNS prefetching and speculative connections.
# Use: Stops the browser from "guessing" where you might click next.
# ✅ SAFE: Standard functional privacy.
SECURITY_BLOCK_DNS_PREFETCH=true
SECURITY_BLOCK_PRECONNECT=true


# =============================================================================
# --- 🕵️ SECTION 4: PRIVACY & AD-BLOCKING (SAFE FEATURES) ---
# =============================================================================
# Active filtering to stop corporate tracking and annoying advertisements.

# 4.1 Master Tracker Blocking
# Uses a built-in blocklist of 50,000+ domains to kill tracking scripts.
# ✅ SAFE: Designed to block trackers while keeping the main website functional.
SECURITY_BLOCK_TRACKERS=true

# 4.2 Aggressive Ad-Blocking Pattern Recognition
# Kills ads by detecting common URL patterns (e.g., /ads/, /analytics/).
# ✅ SAFE: Improves page load speed and battery life.
SECURITY_AGGRESSIVE_AD_BLOCKING=true

# 4.3 URL Parameter Sanitization
# Strips tracking suffixes like ?utm_source= and ?fbclid= before navigation.
# ✅ SAFE: Cleans your links without breaking the page.
SECURITY_REMOVE_TRACKING_PARAMS=true


# =============================================================================
# --- 🧪 SECTION 5: ANTI-FINGERPRINTING ---
# =============================================================================
# Prevents websites from identifying your specific device hardware.

# 5.1 Fingerprint Protection Level
# [STRICT] = Randomizes Canvas, Audio, GPU, and Screen IDs every session.
# [BALANCED] = Realistic profiles to blend into the crowd.
SECURITY_FINGERPRINT_LEVEL=STRICT

# 5.2 Forensic Session Timeout
# Automatically wipes all session data if the app is idle for this long.
# Default: 120,000ms (2 Minutes).
SECURITY_SESSION_TIMEOUT_MS=120000


# =============================================================================
# --- ⚠️ SECTION 6: EXPERIMENTAL & RISKY (SET TO FALSE) ---
# =============================================================================
# These features provide "Paranoid" security but WILL break most major sites.
# ALL SET TO FALSE FOR NORMAL BROWSING COMPATIBILITY.

# 6.1 Block Third-Party Network Requests
# ⚠️ BREAKS SITES: Blocks CSS/Images if they aren't on the same domain.
SECURITY_BLOCK_THIRD_PARTY_REQUESTS=false

# 6.2 Block Third-Party JavaScript
# ⚠️ BREAKS SITES: Most sites load code from CDNs (Google, Cloudflare).
SECURITY_BLOCK_THIRD_PARTY_SCRIPTS=false

# 6.3 Block Service Workers & WebSockets
# ⚠️ BREAKS SITES: Disables modern features like login sync and real-time chat.
SECURITY_BLOCK_SERVICE_WORKERS=false
SECURITY_BLOCK_WEBSOCKETS=false

# 6.4 Content-Security Hardening (Inline Scripts & Eval)
# ⚠️ BREAKS SITES: Prevents sites from initializing their own UI.
SECURITY_BLOCK_INLINE_SCRIPTS=false
SECURITY_BLOCK_EVAL=false

# 6.5 Referrer & First-Party Isolation
# ⚠️ MAY BREAK SITES: Some logins require these tracking headers to work.
SECURITY_STRIP_REFERRERS=false
SECURITY_STRICT_FIRST_PARTY_ISOLATION=false

# 6.6 System Loopback Proxy (DoH)
# ⚠️ EXPERIMENTAL: May cause connection issues on some networks.
SECURITY_ENFORCE_LOOPBACK_PROXY=false


# =============================================================================
# --- 🧹 SECTION 7: FORENSIC PURGE & STEALTH ---
# =============================================================================
# Physical protection for the data stored in your phone's RAM.

# 7.1 Forensic RAM Scramble
# If true, Amnos fills sensitive memory buffers with random noise before clearing.
SECURITY_FORENSIC_RAM_SCRAMBLE=true

# 7.2 Automatic Ghost Wipe Triggers
# Destroys all browser state immediately when screen is off or app is backgrounded.
SECURITY_WIPE_ON_SCREEN_OFF=true
SECURITY_WIPE_ON_BACKGROUND=true
SECURITY_BACKGROUND_WIPE_DELAY_MS=5000

# 7.3 Stealth Camouflage PIN
# The PIN used to unlock the real app from behind a decoy (like a calculator).
SECURITY_DECOY_UNLOCK_PIN=1111


# =============================================================================
# 📋 QUICK REFERENCE GUIDE
# =============================================================================
# 🟢 NORMAL BROWSING: All Section 6 features must be FALSE. 
# 🔴 PARANOID MODE: Set Section 6 to TRUE (Expect blank pages and errors).
# 🔧 DEBUGGING: Set Section 2 to FALSE.
# =============================================================================
