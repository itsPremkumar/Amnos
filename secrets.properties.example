# Google Play Store Signing Credentials
# 1. Create a Keystore (.jks) file in your project root or elsewhere.
# 2. Fill in the paths and passwords below.
# 3. RENAME THIS FILE TO 'secrets.properties' (remove .example).
# 4. NEVER commit 'secrets.properties' to version control!

RELEASE_STORE_FILE=my-release-key.jks
RELEASE_STORE_PASSWORD=your_keystore_password
RELEASE_KEY_ALIAS=your_key_alias
RELEASE_KEY_PASSWORD=your_key_password
